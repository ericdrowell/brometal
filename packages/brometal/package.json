{
  "name": "brometal",
  "version": "0.10.0",
  "description": "Write shaders in TypeScript, compiled at build time to GLSL + WGSL, with a tiny WebGL2 / WebGPU runtime. Write TypeScript. Lift Shaders. Ship Shredded.",
  "license": "MIT",
  "author": "Eric Rowell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericdrowell/brometal.git",
    "directory": "packages/brometal"
  },
  "homepage": "https://brometal.dev",
  "bugs": "https://github.com/ericdrowell/brometal/issues",
  "keywords": [
    "webgpu",
    "wgsl",
    "webgl",
    "webgl2",
    "glsl",
    "shader",
    "shaders",
    "compiler",
    "typescript",
    "gpu",
    "graphics",
    "3d",
    "renderer",
    "rendering",
    "gltf",
    "instancing"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shader-functions": {
      "types": "./dist/shader-functions/index.d.ts",
      "import": "./dist/shader-functions/index.js"
    },
    "./shaders": {
      "types": "./dist/shaders/index.d.ts",
      "import": "./dist/shaders/index.js"
    }
  },
  "bin": {
    "brometal": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/gen-shaders.mjs && tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "gen:shaders": "node scripts/gen-shaders.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@webgpu/types": "^0.1.71",
    "vitest": "^2.1.0"
  }
}
