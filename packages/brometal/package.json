{
  "name": "brometal",
  "version": "0.2.0",
  "description": "Write TypeScript. Lift shaders. Skip leg day.",
  "license": "MIT",
  "author": "Eric Rowell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericdrowell/brometal.git",
    "directory": "packages/brometal"
  },
  "homepage": "https://github.com/ericdrowell/brometal#readme",
  "bugs": "https://github.com/ericdrowell/brometal/issues",
  "keywords": [
    "webgl",
    "webgl2",
    "glsl",
    "shader",
    "compiler",
    "typescript",
    "gpu",
    "graphics",
    "instancing"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "brometal": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^2.1.0"
  }
}
